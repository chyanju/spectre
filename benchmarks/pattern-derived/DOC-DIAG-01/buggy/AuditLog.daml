-- DOC-DIAG-01 BUGGY: Audit event template with actor as signatory
-- The actor who performed the action is the signatory, which means
-- they can unilaterally archive the audit record, erasing evidence.

module Synthetic.AuditLog where

template AuditEntry
  with
    admin : Party
    actor : Party
    action : Text
    timestamp : Time
  where
    signatory actor    -- BUG: actor can archive their own audit records
    observer admin
