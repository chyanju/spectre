--- buggy/DecimalCompare.daml	2026-04-14 19:33:47.794412173 -0700
+++ fixed/DecimalCompare.daml	2026-04-14 19:33:52.115376300 -0700
@@ -1,14 +1,15 @@
 module Obsidian.DecimalCompare where
 
--- BUGGY: Uses exact equality (==) on computed Decimal values,
--- which may fail due to rounding in fixed-point arithmetic.
+-- FIXED: Uses epsilon-based comparison for computed Decimal values.
 
 template PoolRebalancer
   with
     admin : Party
     targetRatio : Decimal
+    epsilon : Decimal  -- tolerance for comparison
   where
     signatory admin
+    ensure epsilon > 0.0
 
     choice Rebalance : ()
       with
@@ -18,11 +19,12 @@
       do
         assertMsg "Amounts must be positive" (currentA > 0.0 && currentB > 0.0)
         let currentRatio = currentA / currentB
-        -- BUG: Exact comparison on a computed ratio.
-        -- Due to fixed-point rounding, currentA / currentB may not
-        -- exactly equal targetRatio even when the pool is balanced.
-        if currentRatio == targetRatio
-          then pure ()  -- balanced
+        -- FIXED: Use epsilon-based comparison instead of exact equality
+        let diff = if currentRatio >= targetRatio
+              then currentRatio - targetRatio
+              else targetRatio - currentRatio
+        if diff <= epsilon
+          then pure ()  -- balanced within tolerance
           else do
             -- perform rebalance
             pure ()
@@ -43,5 +45,6 @@
       do
         let oldProduct = reserveA * reserveB
         let newProduct = newReserveA * newReserveB
-        -- BUG: Exact comparison of computed products
-        pure (oldProduct == newProduct)
+        -- FIXED: New product must be >= old product (no loss),
+        -- rather than exact equality which fails due to rounding.
+        pure (newProduct >= oldProduct)
